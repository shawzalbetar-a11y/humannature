rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // التصريح بقراءة المنتجات والتصنيفات للمستخدمين (مهم لعرض الموقع لعامة الناس)
    match /products/{document=**} {
      allow read: if true;
      allow write: if false; // يجب استخدام لوحة التحكم (Admin SDK) للتعديل
    }
    match /categories/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /subcategories/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // تصريحات المستخدمين (الملف الشخصي، العناوين، البطاقات، المفضلة)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // لتشمل المجموعات الفرعية مثل /addresses و /cards و /favorites
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /orders/{document=**} {
      // السماح بإنشاء طلب جديد بشرط أن يكون رقم المستخدم مطابقاً
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // السماح بقراءة أو تعديل الطلبات الخاصة بالمستخدم نفسه فقط
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // إغلاق أي طلبات قراءة أو كتابة أخرى غير محددة لتأمين قواعد البيانات
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
